# Server
PORT=3001
NODE_ENV=development

# Database — PostgreSQL (required by current Prisma schema)
# Supabase example:
# DATABASE_URL="postgresql://postgres.<project-ref>:<db-password>@aws-0-<region>.pooler.supabase.com:6543/postgres?sslmode=require"
# Local Docker example:
# DATABASE_URL="postgresql://postgres:dev@localhost:5432/eventpulse"
DATABASE_URL="postgresql://postgres:dev@localhost:5432/eventpulse"

# Redis (optional — app uses in-memory cache fallback if not set)
REDIS_URL=

# External APIs (needed in Phase 2)
TMDB_API_KEY=
FOOTBALL_DATA_KEY=
CRICKET_API_KEY=
RAWG_API_KEY=

# Auth secret (needed in Phase 3) — change to a long random string in production
JWT_SECRET=dev_secret_change_this_before_production

# Web Push / VAPID (needed for push notifications — Phase 4)
# Generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=admin@eventpulse.app

# CORS — comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000
